# ==========================================
# Hermes FG Portfolio Gitignore
# ==========================================

# --- Operating System Files ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Text Editor & IDE Settings ---
# Keeps your personal workspace configs out of the repo
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~

# --- Documentation Build Outputs ---
# If you run local Markdown previews or site generators (like MkDocs, Jekyll, or VitePress)
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
build/
dist/
site/
.docusaurus/

# --- Environment & Secret Variables ---
# Essential safety if you ever test API scripts or automated workflows
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# --- Node / Package Managers ---
# If you use markdown linting tools or mermaid-cli locally
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*